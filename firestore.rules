rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isSharingEnabled(patientId) {
      return getUserData(patientId).isSharing == true;
    }

    function isDoctor() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'doctor';
    }

    // Validation helpers
    function isValidUser(data) {
      return data.keys().hasAll(['role', 'name', 'email']) &&
             data.role in ['patient', 'doctor'] &&
             data.name is string && data.name.size() > 0 &&
             data.email is string;
    }

    function isValidRecord(data) {
      return data.keys().hasAll(['patientId', 'fileURL', 'type', 'fileName', 'createdAt']) &&
             data.patientId is string &&
             data.fileURL is string &&
             data.type in ['prescription', 'report'] &&
             data.fileName is string &&
             data.createdAt == request.time;
    }

    // Routes
    match /users/{userId} {
      allow get: if isSignedIn(); // Allow anyone logged in to see profiles (needed for doctor view)
      allow list: if false; // Deny listing users for privacy
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'address', 'age', 'gender', 'bloodGroup', 'degree', 'isSharing']);
    }

    match /records/{recordId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.patientId) || 
        (isDoctor() && isSharingEnabled(resource.data.patientId))
      );
      allow create: if isSignedIn() && 
                    isOwner(request.resource.data.patientId) && 
                    isValidRecord(request.resource.data);
      allow delete: if isSignedIn() && isOwner(resource.data.patientId);
      allow update: if false; // Records are immutable after creation
    }
  }
}
